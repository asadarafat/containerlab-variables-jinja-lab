{# =========================
   Full-mesh containerlab topology (Jinja2)
   - Nodes: r1..rN
   - Mgmt subnet: 99.1.<instance_id>.0/24
   - Mgmt IP: 99.1.<instance_id>.<10 + node_number>
   - Links: full mesh, no duplicates
   - Interfaces: per-node eth index increments as links are added
   ========================= #}

{% set seed_name   = seed_name   | default("topo-mesh") %}
{% set node_image  = node_image  | default("alpine:latest") %} {# use harbor.nice.nokia.net/docker/alpine:latest if needed #}
{% set mgmt_network = mgmt_network | default("stuttgart") %}
{% set node_count  = node_count  | default(4) %}

name: {{ seed_name }}-{{ instance_id }}

mgmt:
  network: {{ mgmt_network }}
  ipv4-subnet: 99.1.{{ instance_id }}.0/24

topology:
  nodes:
{# Generate nodes r1..rN #}
{% for i in range(1, node_count + 1) %}
    r{{ i }}:
      kind: linux
      image: {{ node_image }}
      mgmt-ipv4: 99.1.{{ instance_id }}.{{ 10 + i }}
{% endfor %}

  links:
{#
  Interface numbering rule:
  - Each node rX uses eth1..ethK based on how many links it participates in.
  We compute eth index for each endpoint using simple math:

  For link (i,j) with i<j:
    r_i uses eth = (j - 1)        because it connects to all higher nodes.
    r_j uses eth = (i)            because it connects to all lower nodes.
#}
{% for i in range(1, node_count + 1) %}
{% for j in range(i + 1, node_count + 1) %}
    - endpoints: ["r{{ i }}:eth{{ j - 1 }}", "r{{ j }}:eth{{ i }}"]
{% endfor %}
{% endfor %}
